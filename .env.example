# Copy to .env and fill in real values. Never commit .env.

# --- Database (Neon Postgres) ------------------------------------------------
# Pooled connection string (PgBouncer) — used by the app at runtime.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require"
# Direct (unpooled) connection string — used by Prisma Migrate.
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require"

# --- Auth ---------------------------------------------------------------------
# Random 64+ char secret used to sign session JWTs. Generate with:
#   openssl rand -base64 48
SESSION_SECRET=""
# AES-256-GCM key encrypting integration secrets (Paystack/Flutterwave etc.)
# at rest — this is the only provider-related secret that lives in an env
# var; the actual provider keys are configured by Super Admin at
# /admin/integrations and stored encrypted under this key. Generate with:
#   openssl rand -base64 32
SETTINGS_ENCRYPTION_KEY=""

# --- Cloudflare R2 Object Storage ------------------------------------------------
# R2 access key/secret from an R2 API token (Cloudflare dashboard -> R2 -> Manage API Tokens).
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Your Cloudflare account id — used to derive the S3 API endpoint
# (https://<account_id>.r2.cloudflarestorage.com) if R2_ENDPOINT isn't set explicitly.
R2_ACCOUNT_ID=""
# Optional: set explicitly to override the derived endpoint above.
R2_ENDPOINT=""
# Public read base URL for uploaded files — a custom domain mapped to the
# bucket, or the bucket's enabled r2.dev URL (e.g. https://pub-xxxx.r2.dev).
# The S3 API endpoint above is not publicly readable, so this is required
# for any image/file URL stored in the database to actually load.
R2_PUBLIC_URL=""

# --- Google OAuth (Sign in with Google) ------------------------------------------
# From a Google Cloud Console project -> APIs & Services -> Credentials ->
# OAuth client ID (type: Web application). Authorized redirect URI must be
# exactly: <NEXT_PUBLIC_APP_URL>/api/auth/google/callback
# Leave blank to hide the "Continue with Google" buttons.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- App ------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Admin subdomain (optional) --------------------------------------------------
# Serves /admin as its own subdomain, e.g. "admin.selectapick.store" — same
# deployment, proxy.ts rewrites bare paths on this host to /admin/... under
# the hood. Leave both blank to keep using /admin on the main domain only.
NEXT_PUBLIC_ADMIN_HOST=""
# Cookie Domain (leading dot) shared between the main site and the admin
# subdomain so one login works on both, e.g. ".selectapick.store".
COOKIE_DOMAIN=""
