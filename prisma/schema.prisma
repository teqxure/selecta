// Selecta database schema.
// Foundational models only — kept intentionally minimal per phase-1 scope.
// Connection URLs live in `prisma.config.ts` / `.env` (Prisma 7 no longer
// reads `url`/`directUrl` from the datasource block).

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  BUYER
  SELLER
  AGENT
  ADMIN
  SUPER_ADMIN
}

enum SellerVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

enum SellerProductType {
  MALE_CLOTHES
  FEMALE_CLOTHES
  CHILDREN_CLOTHES
  SHOES
  BAGS
  ACCESSORIES
}

enum ProductStatus {
  DRAFT
  ACTIVE
  SOLD
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  HELD_IN_ESCROW
  RELEASED
  REFUNDED
  FAILED
}

enum DeliveryStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum NotificationType {
  ORDER
  PAYMENT
  DELIVERY
  SYSTEM
  PROMOTION
}

// ---------------------------------------------------------------------------
// Core identity
// ---------------------------------------------------------------------------

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  phone           String?    @unique
  passwordHash    String?    @map("password_hash")
  firstName       String     @map("first_name")
  lastName        String     @map("last_name")
  avatarUrl       String?    @map("avatar_url")
  role            Role       @default(BUYER)
  status          UserStatus @default(ACTIVE)
  city            String?
  state           String?
  preferences     Json?
  emailVerifiedAt DateTime?  @map("email_verified_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  sellerProfile   SellerProfile?
  wallet          Wallet?
  orders          Order[]
  reviews         Review[]
  notifications   Notification[]
  deliveries      Delivery[]      @relation("AgentDeliveries")
  auditLogs       AuditLog[]
  addresses       Address[]
  activities      UserActivity[]
  loginHistory    LoginHistory[]
  assignedSellers SellerProfile[] @relation("SellerAgent")

  @@index([role])
  @@index([status])
  @@map("users")
}

model SellerProfile {
  id                    String                   @id @default(cuid())
  userId                String                   @unique @map("user_id")
  businessName          String                   @map("business_name")
  storeName             String?                  @map("store_name")
  bio                   String?
  marketLocation        String?                  @map("market_location")
  city                  String?
  state                 String?
  country               String                   @default("Nigeria")
  categoryTags          SellerProductType[]      @map("category_tags")
  verificationStatus    SellerVerificationStatus @default(PENDING) @map("verification_status")
  ratingAverage         Float                    @default(0) @map("rating_average")
  ratingCount           Int                      @default(0) @map("rating_count")
  totalSales            Int                      @default(0) @map("total_sales")
  onboardingStep        Int                      @default(1) @map("onboarding_step")
  onboardingCompletedAt DateTime?                @map("onboarding_completed_at")
  agentId               String?                  @map("agent_id")
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent        User?               @relation("SellerAgent", fields: [agentId], references: [id], onDelete: SetNull)
  products     Product[]
  verification SellerVerification?

  @@index([verificationStatus])
  @@index([agentId])
  @@map("seller_profiles")
}

/// Seller onboarding step 3 submission: documents + admin review trail.
/// `SellerProfile.verificationStatus` is a denormalized copy of `status`
/// here, kept in sync by the seller-verification service, so RBAC/UI checks
/// never need to join into this table.
model SellerVerification {
  id                  String                   @id @default(cuid())
  sellerProfileId     String                   @unique @map("seller_profile_id")
  businessPhotoUrl    String?                  @map("business_photo_url")
  shopPhotoUrl        String?                  @map("shop_photo_url")
  identityDocumentUrl String?                  @map("identity_document_url")
  status              SellerVerificationStatus @default(PENDING)
  reviewedById        String?                  @map("reviewed_by_id")
  reviewNotes         String?                  @map("review_notes")
  submittedAt         DateTime                 @default(now()) @map("submitted_at")
  reviewedAt          DateTime?                @map("reviewed_at")

  sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("seller_verifications")
}

model Address {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  label     String?
  line1     String
  line2     String?
  city      String
  state     String
  country   String   @default("Nigeria")
  phone     String?
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

/// Lightweight behavioral event stream (logins, views, profile edits).
/// Distinct from `AuditLog`, which is the admin-facing security/audit trail
/// keyed by entity rather than by user.
model UserActivity {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("user_activities")
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  success   Boolean
  reason    String?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("login_history")
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  imageUrl  String?  @map("image_url")
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([parentId])
  @@map("categories")
}

model Product {
  id          String        @id @default(cuid())
  sellerId    String        @map("seller_id")
  categoryId  String        @map("category_id")
  title       String
  description String?
  price       Decimal       @db.Decimal(10, 2)
  currency    String        @default("NGN")
  quantity    Int           @default(1)
  images      String[]
  status      ProductStatus @default(DRAFT)
  viewCount   Int           @default(0) @map("view_count")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  seller     SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category   Category      @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
  reviews    Review[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
  @@map("products")
}

// ---------------------------------------------------------------------------
// Commerce
// ---------------------------------------------------------------------------

model Order {
  id              String      @id @default(cuid())
  buyerId         String      @map("buyer_id")
  status          OrderStatus @default(PENDING)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(10, 2)
  currency        String      @default("NGN")
  shippingAddress Json        @map("shipping_address")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  buyer    User        @relation(fields: [buyerId], references: [id])
  items    OrderItem[]
  payment  Payment?
  delivery Delivery?

  @@index([buyerId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  unitPrice Decimal  @map("unit_price") @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String        @unique @map("order_id")
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("NGN")
  provider          String
  providerReference String?       @unique @map("provider_reference")
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("payments")
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  balance   Decimal  @default(0) @db.Decimal(10, 2)
  currency  String   @default("NGN")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Review {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  authorId  String   @map("author_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@index([productId])
  @@map("reviews")
}

// ---------------------------------------------------------------------------
// Logistics
// ---------------------------------------------------------------------------

model Delivery {
  id           String         @id @default(cuid())
  orderId      String         @unique @map("order_id")
  agentId      String?        @map("agent_id")
  status       DeliveryStatus @default(PENDING)
  address      Json
  trackingCode String?        @unique @map("tracking_code")
  estimatedAt  DateTime?      @map("estimated_at")
  deliveredAt  DateTime?      @map("delivered_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  agent User? @relation("AgentDeliveries", fields: [agentId], references: [id])

  @@index([agentId])
  @@index([status])
  @@map("deliveries")
}

// ---------------------------------------------------------------------------
// Platform
// ---------------------------------------------------------------------------

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
  @@map("audit_logs")
}
