// Selecta database schema.
// Foundational models only — kept intentionally minimal per phase-1 scope.
// Connection URLs live in `prisma.config.ts` / `.env` (Prisma 7 no longer
// reads `url`/`directUrl` from the datasource block).

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  BUYER
  SELLER
  AGENT
  ADMIN
  SUPER_ADMIN
}

enum SellerVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

enum SellerProductType {
  MALE_CLOTHES
  FEMALE_CLOTHES
  CHILDREN_CLOTHES
  SHOES
  BAGS
  ACCESSORIES
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  SOLD
  REJECTED
  REMOVED
}

enum ConditionGrade {
  SELECTA_GOLD
  SELECTA_CLASSIC
  SELECTA_VALUE
}

enum ProductGender {
  MALE
  FEMALE
  UNISEX
  KIDS
}

enum ProductImageKind {
  FRONT
  BACK
  DETAIL
  DEFECT
  OTHER
}

enum ProductEventType {
  VIEW
  SAVE
  UNSAVE
  SHARE
  CONTACT_SELLER
  /// One row per product shown on a search results page — batched via
  /// `createMany` per search, not one query per product. Backs seller
  /// "search appearances" insight and admin search analytics. Deliberately
  /// NOT logged for homepage sections (would multiply write volume for
  /// every visit with no proportional analytical value).
  IMPRESSION
}

enum OrderStatus {
  CREATED
  AWAITING_PAYMENT
  PAID
  PROCESSING
  READY_FOR_PICKUP
  IN_TRANSIT
  DELIVERED
  COMPLETED
  DISPUTED
  CANCELLED
  /// Terminal — reached only via dispute resolution siding with the
  /// buyer. Distinct from CANCELLED (never fulfilled) since a refunded
  /// order was paid for and may have shipped; the money simply came back.
  REFUNDED
}

enum PaymentStatus {
  PENDING
  HELD_IN_ESCROW
  RELEASED
  REFUNDED
  FAILED
}

/// Per-seller payout ledger status — a superset of Payment's lifecycle
/// because escrow hold/release happens per seller, not per order (one
/// order can contain items from several sellers).
enum TransactionStatus {
  PENDING
  SUCCESSFUL
  FAILED
  HELD_IN_ESCROW
  RELEASED
  REFUNDED
}

enum DeliveryStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum DeliveryMethod {
  MANUAL
  PARTNER
}

enum WithdrawalStatus {
  REQUESTED
  PROCESSING
  PAID
  REJECTED
}

enum DisputeType {
  WRONG_ITEM
  DAMAGED_ITEM
  NOT_RECEIVED
  OTHER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_REFUND
  RESOLVED_RELEASE
  RESOLVED_PARTIAL
  CLOSED
}

enum IntegrationCategory {
  PAYMENT
  STORAGE
  EMAIL
  SMS
  AI
}

enum MarketplaceStatus {
  OPEN
  PAUSED
  CLOSED
}

enum NotificationType {
  ORDER
  PAYMENT
  DELIVERY
  SYSTEM
  PROMOTION
  MESSAGE
}

// ---------------------------------------------------------------------------
// Core identity
// ---------------------------------------------------------------------------

model User {
  id                    String     @id @default(cuid())
  email                 String     @unique
  phone                 String?    @unique
  passwordHash          String?    @map("password_hash")
  /// Google's stable account identifier ("sub" claim) — set once a user
  /// signs in with Google, whether that creates a brand-new account or
  /// links to an existing email/password one. Never null for a
  /// Google-only account (which also has passwordHash: null).
  googleId              String?    @unique @map("google_id")
  firstName             String     @map("first_name")
  lastName              String     @map("last_name")
  avatarUrl             String?    @map("avatar_url")
  role                  Role       @default(BUYER)
  status                UserStatus @default(ACTIVE)
  /// Individually-granted permission strings — only meaningful when role
  /// is ADMIN. SUPER_ADMIN's authority is implicit (wildcard, never
  /// stored); SELLER/BUYER get a fixed role-wide set defined in code, not
  /// per-user grants. See lib/auth/permissions.ts.
  permissions           String[]   @default([])
  city                  String?
  state                 String?
  preferences           Json?
  emailVerifiedAt       DateTime?  @map("email_verified_at")
  /// Set by Super Admin to block sending new messages (not a full account
  /// suspension) — see Phase 11's "restrict messaging" admin action.
  /// Checked in conversation.service.ts before every send.
  messagingRestrictedAt DateTime?  @map("messaging_restricted_at")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")

  sellerProfile   SellerProfile?
  wallet          Wallet?
  orders          Order[]
  reviews         Review[]
  notifications   Notification[]
  deliveries      Delivery[]      @relation("AgentDeliveries")
  auditLogs       AuditLog[]
  addresses       Address[]
  activities      UserActivity[]
  loginHistory    LoginHistory[]
  sessions        Session[]
  assignedSellers SellerProfile[] @relation("SellerAgent")
  savedProducts   SavedProduct[]
  productEvents   ProductEvent[]
  cartItems       CartItem[]
  storeFollows    StoreFollow[]
  conversations   Conversation[]  @relation("BuyerConversations")
  messages        Message[]
  searchQueries   SearchQuery[]

  transactionsAsBuyer       Transaction[]              @relation("BuyerTransactions")
  orderStatusChanges        OrderStatusHistory[]
  withdrawalReviews         Withdrawal[]               @relation("WithdrawalReviewer")
  disputesAsBuyer           Dispute[]                  @relation("BuyerDisputes")
  disputesResolved          Dispute[]                  @relation("ResolvedDisputes")
  systemSettingsUpdated     SystemSettings[]
  integrationSettingsSet    IntegrationSetting[]
  commissionRulesCreated    CommissionRule[]
  featureFlagsUpdated       FeatureFlag[]
  ledgerEntries             LedgerEntry[]
  ledgerEntriesRecorded     LedgerEntry[]              @relation("LedgerEntryActor")
  emailTemplatesUpdated     EmailTemplate[]
  notificationDeliveries    NotificationDelivery[]
  subscriptionPlansCreated  SubscriptionPlan[]
  growthPartnerApplications GrowthPartnerApplication[]
  offersAsBuyer             Offer[]                    @relation("BuyerOffers")
  messageFlags              MessageFlag[]

  @@index([role])
  @@index([status])
  @@map("users")
}

model SellerProfile {
  id                    String                   @id @default(cuid())
  userId                String                   @unique @map("user_id")
  businessName          String                   @map("business_name")
  storeName             String?                  @map("store_name")
  storeSlug             String?                  @unique @map("store_slug")
  logoUrl               String?                  @map("logo_url")
  bannerUrl             String?                  @map("banner_url")
  bio                   String?
  /// Free-form { instagram?, tiktok?, facebook? } handles/URLs shown on the
  /// public storefront — distinct from the in-message contact-safety system,
  /// since a public "follow us" link isn't the off-platform-payment/DM
  /// leakage that system guards against.
  socialLinks           Json?                    @map("social_links")
  marketLocation        String?                  @map("market_location")
  city                  String?
  state                 String?
  country               String                   @default("Nigeria")
  categoryTags          SellerProductType[]      @map("category_tags")
  /// Set once, the first time a seller accepts the Seller Agreement during
  /// onboarding (see app/(buyer)/seller-agreement). Never cleared or
  /// re-prompted — a version bump to the agreement itself would need its
  /// own re-acceptance mechanism, not implemented yet.
  agreementAcceptedAt   DateTime?                @map("agreement_accepted_at")
  verificationStatus    SellerVerificationStatus @default(PENDING) @map("verification_status")
  ratingAverage         Float                    @default(0) @map("rating_average")
  ratingCount           Int                      @default(0) @map("rating_count")
  totalSales            Int                      @default(0) @map("total_sales")
  followerCount         Int                      @default(0) @map("follower_count")
  profileViewCount      Int                      @default(0) @map("profile_view_count")
  onboardingStep        Int                      @default(1) @map("onboarding_step")
  onboardingCompletedAt DateTime?                @map("onboarding_completed_at")
  agentId               String?                  @map("agent_id")
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")

  user                     User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent                    User?                      @relation("SellerAgent", fields: [agentId], references: [id], onDelete: SetNull)
  products                 Product[]
  verification             SellerVerification?
  followers                StoreFollow[]
  conversations            Conversation[]
  transactions             Transaction[]
  withdrawals              Withdrawal[]
  disputes                 Dispute[]
  ledgerEntries            LedgerEntry[]
  subscriptions            SellerSubscription[]
  boostCampaigns           BoostCampaign[]
  monetizationPayments     MonetizationPayment[]
  growthPartnerApplication GrowthPartnerApplication[]
  offers                   Offer[]
  aiFeatureUsages          AiFeatureUsage[]

  @@index([verificationStatus])
  @@index([agentId])
  @@map("seller_profiles")
}

/// A buyer following a store — also doubles as "save store" (section 4),
/// same one-tap-interaction pattern as SavedProduct in the catalog phase.
model StoreFollow {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  sellerProfileId String   @map("seller_profile_id")
  createdAt       DateTime @default(now()) @map("created_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@unique([userId, sellerProfileId])
  @@index([sellerProfileId])
  @@map("store_follows")
}

/// Seller onboarding step 3 submission: documents + admin review trail.
/// `SellerProfile.verificationStatus` is a denormalized copy of `status`
/// here, kept in sync by the seller-verification service, so RBAC/UI checks
/// never need to join into this table.
model SellerVerification {
  id                  String                   @id @default(cuid())
  sellerProfileId     String                   @unique @map("seller_profile_id")
  businessPhotoUrl    String?                  @map("business_photo_url")
  shopPhotoUrl        String?                  @map("shop_photo_url")
  identityDocumentUrl String?                  @map("identity_document_url")
  status              SellerVerificationStatus @default(PENDING)
  reviewedById        String?                  @map("reviewed_by_id")
  reviewNotes         String?                  @map("review_notes")
  submittedAt         DateTime                 @default(now()) @map("submitted_at")
  reviewedAt          DateTime?                @map("reviewed_at")

  sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("seller_verifications")
}

model Address {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  label     String?
  line1     String
  line2     String?
  city      String
  state     String
  country   String   @default("Nigeria")
  phone     String?
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

/// Lightweight behavioral event stream (logins, views, profile edits).
/// Distinct from `AuditLog`, which is the admin-facing security/audit trail
/// keyed by entity rather than by user.
model UserActivity {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("user_activities")
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  success   Boolean
  reason    String?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("login_history")
}

/// One row per issued session JWT — this is what makes "view active
/// sessions" / "terminate this session" / "force logout everywhere"
/// possible at all, since the JWT itself is a stateless bearer token that
/// can't otherwise be revoked before its natural expiry. The JWT carries
/// this row's id as its `sid` claim; `currentUser()` checks `revokedAt` on
/// every request. `expiresAt` reflects the value at issuance only — the
/// sliding-refresh in proxy.ts re-signs the JWT with a later `exp` without
/// touching this row (proxy is deliberately DB-free), so treat `expiresAt`
/// as informational and `revokedAt` as the sole authority on validity.
/// Sessions created before this model existed have no matching row at all
/// — `currentUser()` treats a JWT with no `sid` claim as unrevocable
/// (pre-existing behavior), so already-logged-in users aren't force-logged-out
/// by this migration; they age out naturally within their existing expiry.
model Session {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  imageUrl  String?  @map("image_url")
  parentId  String?  @map("parent_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent          Category?        @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        Category[]       @relation("CategoryHierarchy")
  products        Product[]        @relation("ProductCategory")
  subcategoryOf   Product[]        @relation("ProductSubcategory")
  commissionRules CommissionRule[]

  @@index([parentId])
  @@map("categories")
}

model Product {
  id              String         @id @default(cuid())
  sellerId        String         @map("seller_id")
  categoryId      String         @map("category_id")
  subcategoryId   String?        @map("subcategory_id")
  title           String
  description     String?
  brand           String?
  color           String?
  gender          ProductGender?
  size            String?
  price           Decimal        @db.Decimal(10, 2)
  discountPrice   Decimal?       @map("discount_price") @db.Decimal(10, 2)
  estimatedValue  Decimal?       @map("estimated_value") @db.Decimal(10, 2)
  currency        String         @default("NGN")
  quantity        Int            @default(1)
  conditionGrade  ConditionGrade @default(SELECTA_CLASSIC) @map("condition_grade")
  status          ProductStatus  @default(DRAFT)
  material        String?
  city            String?
  state           String?
  market          String?
  pickupLocation  String?        @map("pickup_location")
  viewCount       Int            @default(0) @map("view_count")
  likeCount       Int            @default(0) @map("like_count")
  shareCount      Int            @default(0) @map("share_count")
  isFeatured      Boolean        @default(false) @map("is_featured")
  rejectionReason String?        @map("rejection_reason")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  seller         SellerProfile   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category       Category        @relation("ProductCategory", fields: [categoryId], references: [id])
  subcategory    Category?       @relation("ProductSubcategory", fields: [subcategoryId], references: [id], onDelete: SetNull)
  images         ProductImage[]
  orderItems     OrderItem[]
  reviews        Review[]
  savedBy        SavedProduct[]
  events         ProductEvent[]
  cartItems      CartItem[]
  boostCampaigns BoostCampaign[]
  conversations  Conversation[]
  offers         Offer[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([status])
  @@index([city, state])
  @@index([isFeatured])
  @@index([brand])
  @@index([price])
  @@index([viewCount])
  @@index([likeCount])
  @@map("products")
}

model ProductImage {
  id            String           @id @default(cuid())
  productId     String           @map("product_id")
  url           String
  kind          ProductImageKind @default(OTHER)
  position      Int              @default(0)
  // Hooks for a future AI pipeline (background removal / enhancement /
  // auto quality scoring) — left null until that service exists.
  processedUrl  String?          @map("processed_url")
  qualityScore  Float?           @map("quality_score")
  aiProcessedAt DateTime?        @map("ai_processed_at")
  createdAt     DateTime         @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
  @@map("product_images")
}

/// Doubles as "like" (section 6/1) and "save" (section 9) — a single tap
/// interaction in the UI, so one model rather than two near-duplicates.
model SavedProduct {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@map("saved_products")
}

/// Raw event stream backing the denormalized Product counters and future
/// recommendation/analytics work — counters stay fast to read, this stays
/// the source of truth for aggregation.
model ProductEvent {
  id        String           @id @default(cuid())
  productId String           @map("product_id")
  userId    String?          @map("user_id")
  type      ProductEventType
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId, type, createdAt])
  @@index([userId])
  @@map("product_events")
}

/// One row per executed search — the source of truth for autocomplete
/// suggestions, "popular searches", "trending keywords", and admin search
/// analytics (top searches, zero-result searches). Logged from
/// `searchProducts` only when a keyword was actually typed (`q` present),
/// not on pure filter/category browsing.
model SearchQuery {
  id          String   @id @default(cuid())
  query       String
  userId      String?  @map("user_id")
  resultCount Int      @map("result_count")
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([query])
  @@index([createdAt])
  @@index([resultCount])
  @@map("search_queries")
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("cart_items")
}

// ---------------------------------------------------------------------------
// Commerce
// ---------------------------------------------------------------------------

model Order {
  id              String      @id @default(cuid())
  buyerId         String      @map("buyer_id")
  status          OrderStatus @default(CREATED)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(10, 2)
  currency        String      @default("NGN")
  shippingAddress Json        @map("shipping_address")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  buyer         User                 @relation(fields: [buyerId], references: [id])
  items         OrderItem[]
  payment       Payment?
  delivery      Delivery?
  transactions  Transaction[]
  statusHistory OrderStatusHistory[]
  disputes      Dispute[]
  ledgerEntries LedgerEntry[]
  conversations Conversation[]
  offer         Offer?

  @@index([buyerId])
  @@index([status])
  @@map("orders")
}

/// Every order status change is recorded here — the timeline shown to
/// buyer/seller/admin, and the audit trail for "who moved this order and
/// when." `actorId` is null for system/webhook-driven transitions.
model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String      @map("order_id")
  status    OrderStatus
  note      String?
  actorId   String?     @map("actor_id")
  createdAt DateTime    @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@map("order_status_history")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  unitPrice Decimal  @map("unit_price") @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  review  Review?

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

/// The buyer-facing capture: one Payment per Order, matching the single
/// charge the provider actually processes. Escrow hold/release happens
/// per seller below in `Transaction`, not here.
model Payment {
  id                String        @id @default(cuid())
  orderId           String        @unique @map("order_id")
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("NGN")
  provider          String
  providerReference String?       @unique @map("provider_reference")
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([status])
  @@map("payments")
}

/// The seller-facing payout ledger: one row per (order, seller) pair,
/// created once payment succeeds, carrying the commission split so a
/// seller's payout is never recomputed from scratch — it's the number
/// that was actually charged and committed at the time.
model Transaction {
  id               String            @id @default(cuid())
  orderId          String            @map("order_id")
  paymentId        String?           @map("payment_id")
  buyerId          String            @map("buyer_id")
  sellerId         String            @map("seller_id")
  amount           Decimal           @db.Decimal(10, 2)
  commissionRate   Float             @map("commission_rate")
  commissionAmount Decimal           @map("commission_amount") @db.Decimal(10, 2)
  sellerAmount     Decimal           @map("seller_amount") @db.Decimal(10, 2)
  currency         String            @default("NGN")
  provider         String
  reference        String?           @unique
  status           TransactionStatus @default(PENDING)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  order   Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  buyer   User          @relation("BuyerTransactions", fields: [buyerId], references: [id])
  seller  SellerProfile @relation(fields: [sellerId], references: [id])

  @@index([sellerId, status])
  @@index([orderId])
  @@index([status])
  @@map("transactions")
}

model Wallet {
  id               String   @id @default(cuid())
  userId           String   @unique @map("user_id")
  balance          Decimal  @default(0) @db.Decimal(10, 2)
  /// Lifetime earnings — never decreases, even once a future withdrawal
  /// phase starts deducting from `balance`. Distinct source of truth from
  /// `balance` on purpose.
  totalEarned      Decimal  @default(0) @map("total_earned") @db.Decimal(10, 2)
  /// Cumulative amount paid out via approved withdrawals.
  withdrawnBalance Decimal  @default(0) @map("withdrawn_balance") @db.Decimal(10, 2)
  currency         String   @default("NGN")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Withdrawal {
  id            String           @id @default(cuid())
  sellerId      String           @map("seller_id")
  amount        Decimal          @db.Decimal(10, 2)
  bankName      String           @map("bank_name")
  accountNumber String           @map("account_number")
  accountName   String           @map("account_name")
  status        WithdrawalStatus @default(REQUESTED)
  reviewedById  String?          @map("reviewed_by_id")
  reviewNotes   String?          @map("review_notes")
  requestedAt   DateTime         @default(now()) @map("requested_at")
  processedAt   DateTime?        @map("processed_at")

  seller     SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  reviewedBy User?         @relation("WithdrawalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([sellerId, status])
  @@map("withdrawals")
}

/// Every type of money movement the platform ever records. Amounts are
/// signed from the perspective of the entity they credit/debit: positive
/// increases what's owed to that entity, negative decreases it. See
/// services/finance/ledger.service.ts for the exact convention used by
/// each type.
enum LedgerEntryType {
  CUSTOMER_PAYMENT
  COMMISSION_EARNED
  VENDOR_CREDIT
  WITHDRAWAL_REQUEST
  WITHDRAWAL_PAID
  REFUND
  ADJUSTMENT
  /// Platform revenue from a seller subscription payment — 100% platform
  /// revenue, no seller split (unlike COMMISSION_EARNED, which is a cut of
  /// a buyer's order).
  SUBSCRIPTION_REVENUE
  /// Platform revenue from a seller paying cash (not subscription credits)
  /// for a product boost campaign.
  BOOST_REVENUE
}

/// Append-only financial journal — the authoritative source for every
/// historical revenue/payout figure (GMV, commission earned, completed
/// payouts, refunds). Nothing here is ever updated or deleted; a
/// correction is made by writing a new offsetting entry (typically
/// ADJUSTMENT), never by editing a prior row. Wallet/Transaction/
/// Withdrawal status columns remain the fast, mutable "current state" —
/// this table is the immutable "what actually happened, in order" record
/// that state is derived from.
model LedgerEntry {
  id            String          @id @default(cuid())
  type          LedgerEntryType
  amount        Decimal         @db.Decimal(10, 2)
  currency      String          @default("NGN")
  /// Free-form correlation id for grouping entries from the same economic
  /// event (e.g. a provider's payment reference) — not a foreign key.
  reference     String?
  userId        String?         @map("user_id")
  sellerId      String?         @map("seller_id")
  orderId       String?         @map("order_id")
  paymentId     String?         @map("payment_id")
  transactionId String?         @map("transaction_id")
  withdrawalId  String?         @map("withdrawal_id")
  /// Who/what caused this entry — null for system-driven entries (webhook
  /// confirmations, escrow release), set for admin-initiated ones (manual
  /// adjustment, withdrawal approval).
  actorId       String?         @map("actor_id")
  note          String?
  metadata      Json?
  createdAt     DateTime        @default(now()) @map("created_at")

  user   User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  seller SellerProfile? @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  order  Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  actor  User?          @relation("LedgerEntryActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([userId])
  @@index([sellerId])
  @@index([orderId])
  @@index([createdAt])
  @@map("ledger_entries")
}

model Review {
  id          String   @id @default(cuid())
  productId   String   @map("product_id")
  authorId    String   @map("author_id")
  /// The specific purchase this review is for — unique, so "one review per
  /// purchased item" is a database guarantee, not just an application
  /// check. Also what proves the reviewer actually bought this (a
  /// "verified purchase" review), not just anyone with an account.
  orderItemId String   @unique @map("order_item_id")
  rating      Int
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("reviews")
}

// ---------------------------------------------------------------------------
// Logistics
// ---------------------------------------------------------------------------

model Delivery {
  id             String         @id @default(cuid())
  orderId        String         @unique @map("order_id")
  agentId        String?        @map("agent_id")
  status         DeliveryStatus @default(PENDING)
  method         DeliveryMethod @default(MANUAL)
  address        Json
  pickupLocation String?        @map("pickup_location")
  deliveryFee    Decimal?       @map("delivery_fee") @db.Decimal(10, 2)
  /// Courier/logistics partner name — free text today (e.g. "GIG Logistics"),
  /// the natural place to switch to a partner-id FK once real logistics
  /// integrations exist.
  courier        String?
  trackingCode   String?        @unique @map("tracking_code")
  estimatedAt    DateTime?      @map("estimated_at")
  deliveredAt    DateTime?      @map("delivered_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  order  Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  agent  User?           @relation("AgentDeliveries", fields: [agentId], references: [id])
  events DeliveryEvent[]

  @@index([agentId])
  @@index([status])
  @@map("deliveries")
}

model DeliveryEvent {
  id         String         @id @default(cuid())
  deliveryId String         @map("delivery_id")
  status     DeliveryStatus
  note       String?
  createdAt  DateTime       @default(now()) @map("created_at")

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId, createdAt])
  @@map("delivery_events")
}

// ---------------------------------------------------------------------------
// Messaging (foundation — buyer/seller only, no groups, no attachments yet)
// ---------------------------------------------------------------------------

enum ConversationType {
  PRODUCT_INQUIRY
  ORDER_SUPPORT
  DISPUTE_DISCUSSION
}

/// One conversation per (buyer, seller, type, product/order/dispute) rather
/// than a single lifetime thread per buyer-seller pair — asking about two
/// different products, or getting order support, are separate threads with
/// their own context. Matching on create is done at the application layer
/// (`getOrCreateConversation`), not a DB unique constraint, since Postgres
/// treats NULL productId/orderId/disputeId columns as always-distinct,
/// which would defeat "reuse the general inquiry thread" matching.
model Conversation {
  id                 String           @id @default(cuid())
  buyerId            String           @map("buyer_id")
  sellerProfileId    String           @map("seller_profile_id")
  type               ConversationType @default(PRODUCT_INQUIRY)
  productId          String?          @map("product_id")
  orderId            String?          @map("order_id")
  disputeId          String?          @map("dispute_id")
  isArchivedByBuyer  Boolean          @default(false) @map("is_archived_by_buyer")
  isArchivedBySeller Boolean          @default(false) @map("is_archived_by_seller")
  isReported         Boolean          @default(false) @map("is_reported")
  reportedAt         DateTime?        @map("reported_at")
  reportReason       String?          @map("report_reason")
  lastMessageAt      DateTime         @default(now()) @map("last_message_at")
  createdAt          DateTime         @default(now()) @map("created_at")

  buyer         User          @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  order         Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  dispute       Dispute?      @relation(fields: [disputeId], references: [id], onDelete: SetNull)
  messages      Message[]
  offers        Offer[]
  flags         MessageFlag[]

  @@index([buyerId, sellerProfileId, type])
  @@index([sellerProfileId, lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  senderId       String    @map("sender_id")
  body           String
  imageUrl       String?   @map("image_url")
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  flag         MessageFlag?

  @@index([conversationId, createdAt])
  @@map("messages")
}

enum MessageFlagType {
  PHONE_NUMBER
  EMAIL_ADDRESS
  WHATSAPP
  EXTERNAL_PAYMENT
  SOCIAL_HANDLE
  BANK_ACCOUNT
}

/// One row per message that matched a contact-sharing/off-platform pattern
/// — the source of truth for the Phase-5 warning flow and Phase-11 admin
/// trust dashboard. `matchedSnippet` is a short, already-redacted excerpt
/// (never the full contact detail) kept only so a reviewer can see *why*
/// it was flagged without the flag table itself becoming a second place
/// the actual phone/email leaks to.
model MessageFlag {
  id             String          @id @default(cuid())
  messageId      String          @unique @map("message_id")
  conversationId String          @map("conversation_id")
  userId         String          @map("user_id")
  flagType       MessageFlagType @map("flag_type")
  matchedSnippet String          @map("matched_snippet")
  createdAt      DateTime        @default(now()) @map("created_at")

  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([conversationId])
  @@map("message_flags")
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  EXPIRED
  CANCELLED
}

/// A price negotiation scoped to one product inquiry conversation. A
/// counter-offer is a new row linked back via `previousOfferId` (the old
/// row moves to COUNTERED) rather than mutating amount in place, so the
/// full back-and-forth stays visible. Accepting creates a real Order at
/// exactly this amount — `order.service.ts#createOrder` re-reads the
/// ACCEPTED offer server-side rather than trusting a client-supplied price,
/// so payment still flows through the existing escrow pipeline unchanged.
model Offer {
  id              String      @id @default(cuid())
  conversationId  String      @map("conversation_id")
  productId       String      @map("product_id")
  buyerId         String      @map("buyer_id")
  sellerId        String      @map("seller_id")
  amount          Decimal     @db.Decimal(10, 2)
  status          OfferStatus @default(PENDING)
  previousOfferId String?     @unique @map("previous_offer_id")
  orderId         String?     @unique @map("order_id")
  expiresAt       DateTime?   @map("expires_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  conversation  Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer         User          @relation("BuyerOffers", fields: [buyerId], references: [id], onDelete: Cascade)
  seller        SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  previousOffer Offer?        @relation("OfferCounters", fields: [previousOfferId], references: [id], onDelete: SetNull)
  counteredBy   Offer?        @relation("OfferCounters")
  order         Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([sellerId, status])
  @@index([buyerId])
  @@map("offers")
}

// ---------------------------------------------------------------------------
// Platform
// ---------------------------------------------------------------------------

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

/// One row per known event key ("order_paid", "seller_approved", etc.) —
/// the Super Admin-editable copy behind every templated email the
/// notification engine sends. `bodyHtml` and `subject` may contain
/// `{{variable}}` placeholders (see services/notifications/template.ts);
/// unknown placeholders are left as-is rather than throwing, so a typo'd
/// variable degrades to visible-but-harmless instead of a broken send.
model EmailTemplate {
  key         String   @id
  label       String
  subject     String
  bodyHtml    String   @map("body_html")
  isEnabled   Boolean  @default(true) @map("is_enabled")
  updatedById String?  @map("updated_by_id")
  updatedAt   DateTime @updatedAt @map("updated_at")

  updatedBy User? @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("email_templates")
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
}

/// Every attempted send through any channel — the audit trail
/// `services/notifications/notify.service.ts` needs to prove an event
/// actually reached (or failed to reach) someone, and the basis for
/// future retry logic. Deliberately separate from `Notification` (the
/// in-app inbox row): one event can produce a `Notification` with zero,
/// one, or several `NotificationDelivery` rows (e.g. email today, SMS
/// later) — they track different things and fail independently.
model NotificationDelivery {
  id            String                     @id @default(cuid())
  userId        String?                    @map("user_id")
  channel       NotificationChannel
  status        NotificationDeliveryStatus @default(PENDING)
  /// Integration provider that handled this attempt (e.g. "resend"), null
  /// until a provider is actually resolved for the send.
  provider      String?
  templateKey   String?                    @map("template_key")
  /// Email address or phone number this attempt targeted — kept even if
  /// the user record is later deleted, since it's the delivery record.
  recipient     String
  attemptCount  Int                        @default(1) @map("attempt_count")
  failureReason String?                    @map("failure_reason")
  sentAt        DateTime?                  @map("sent_at")
  createdAt     DateTime                   @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
  @@map("notification_deliveries")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Disputes
// ---------------------------------------------------------------------------

model Dispute {
  id           String        @id @default(cuid())
  orderId      String        @map("order_id")
  buyerId      String        @map("buyer_id")
  sellerId     String        @map("seller_id")
  type         DisputeType
  description  String
  evidenceUrls String[]      @map("evidence_urls")
  status       DisputeStatus @default(OPEN)
  resolution   String?
  resolvedById String?       @map("resolved_by_id")
  resolvedAt   DateTime?     @map("resolved_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyer         User           @relation("BuyerDisputes", fields: [buyerId], references: [id])
  seller        SellerProfile  @relation(fields: [sellerId], references: [id])
  resolvedBy    User?          @relation("ResolvedDisputes", fields: [resolvedById], references: [id], onDelete: SetNull)
  conversations Conversation[]

  @@index([status])
  @@index([sellerId])
  @@index([orderId])
  @@map("disputes")
}

// ---------------------------------------------------------------------------
// Super Admin platform controls
// ---------------------------------------------------------------------------

/// Singleton row (fixed id "singleton") — global marketplace switches.
model SystemSettings {
  id                        String            @id @default("singleton")
  platformName              String            @default("Selecta") @map("platform_name")
  maintenanceMode           Boolean           @default(false) @map("maintenance_mode")
  maintenanceMessage        String?           @map("maintenance_message")
  allowNewSellers           Boolean           @default(true) @map("allow_new_sellers")
  allowNewBuyers            Boolean           @default(true) @map("allow_new_buyers")
  requireProductApproval    Boolean           @default(true) @map("require_product_approval")
  requireSellerVerification Boolean           @default(true) @map("require_seller_verification")
  marketplaceStatus         MarketplaceStatus @default(OPEN) @map("marketplace_status")
  /// "From" identity for every templated email the notification engine
  /// sends — e.g. "Selecta" <notifications@selectapick.store>. Blank
  /// sender email falls back to a hardcoded default at send time rather
  /// than failing the send outright.
  notificationSenderName    String            @default("Selecta") @map("notification_sender_name")
  notificationSenderEmail   String?           @map("notification_sender_email")
  /// Cash price per day for a product boost campaign when a seller has no
  /// (or insufficient) subscription boost credits to cover it — Super
  /// Admin-configurable, never hardcoded in application code.
  boostPricePerDay          Decimal           @default(500) @map("boost_price_per_day") @db.Decimal(10, 2)
  updatedById               String?           @map("updated_by_id")
  updatedAt                 DateTime          @updatedAt @map("updated_at")

  updatedBy User? @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("system_settings")
}

/// One row per (category, provider) — e.g. (PAYMENT, "paystack"),
/// (STORAGE, "cloudflare-r2"). Actual credentials live in `IntegrationSecret`,
/// never here — this row only holds non-secret config + enable state.
model IntegrationSetting {
  id          String              @id @default(cuid())
  category    IntegrationCategory
  provider    String
  isEnabled   Boolean             @default(false) @map("is_enabled")
  isPrimary   Boolean             @default(false) @map("is_primary")
  config      Json?
  updatedById String?             @map("updated_by_id")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  updatedBy User?               @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  secrets   IntegrationSecret[]

  @@unique([category, provider])
  @@map("integration_settings")
}

/// Encrypted-at-rest credential values. `encryptedValue` is AES-256-GCM
/// ciphertext (iv+authTag+ciphertext packed, base64) — see
/// lib/security/encryption.ts. Only `lastFourDisplay` (plaintext) is ever
/// shown in the UI, masked like `********************x7d9`.
model IntegrationSecret {
  id                   String   @id @default(cuid())
  integrationSettingId String   @map("integration_setting_id")
  key                  String
  encryptedValue       String   @map("encrypted_value")
  lastFourDisplay      String   @map("last_four_display")
  rotatedAt            DateTime @default(now()) @map("rotated_at")
  createdAt            DateTime @default(now()) @map("created_at")

  integrationSetting IntegrationSetting @relation(fields: [integrationSettingId], references: [id], onDelete: Cascade)

  @@unique([integrationSettingId, key])
  @@map("integration_secrets")
}

/// `categoryId = null` is the platform default rate. A category-specific
/// row overrides the default for that category. No commission is ever
/// hardcoded in application code — see services/platform/commission.service.ts.
model CommissionRule {
  id            String    @id @default(cuid())
  categoryId    String?   @map("category_id")
  label         String
  percentage    Float
  isPromotional Boolean   @default(false) @map("is_promotional")
  startsAt      DateTime? @map("starts_at")
  endsAt        DateTime? @map("ends_at")
  isActive      Boolean   @default(true) @map("is_active")
  createdById   String?   @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  category  Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([isActive])
  @@map("commission_rules")
}

model FeatureFlag {
  key         String   @id
  label       String
  description String?
  isEnabled   Boolean  @default(false) @map("is_enabled")
  updatedById String?  @map("updated_by_id")
  updatedAt   DateTime @updatedAt @map("updated_at")

  updatedBy User? @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("feature_flags")
}

// ---------------------------------------------------------------------------
// Monetization — seller subscriptions, product boosts, growth partner
// ---------------------------------------------------------------------------

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum BoostGoal {
  VIEWS
  SAVES
  SALES
}

enum BoostStatus {
  PENDING_PAYMENT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MonetizationPurpose {
  SUBSCRIPTION
  BOOST
}

enum MonetizationPaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum GrowthApplicationStatus {
  PENDING
  REVIEWING
  ACCEPTED
  REJECTED
}

/// Super Admin-controlled membership tier. Never hardcoded in application
/// code — every price/limit/benefit a plan grants lives on this row, read
/// at the point of enforcement (see services/monetization/subscription.service.ts).
model SubscriptionPlan {
  id                   String   @id @default(cuid())
  name                 String   @unique
  slug                 String   @unique
  monthlyPrice         Decimal  @default(0) @map("monthly_price") @db.Decimal(10, 2)
  durationDays         Int      @default(30) @map("duration_days")
  /// Null = unlimited active listings.
  maxProducts          Int?     @map("max_products")
  boostCreditsPerCycle Int      @default(0) @map("boost_credits_per_cycle")
  hasAnalyticsAccess   Boolean  @default(false) @map("has_analytics_access")
  hasFeaturedStore     Boolean  @default(false) @map("has_featured_store")
  hasPrioritySupport   Boolean  @default(false) @map("has_priority_support")
  /// The plan applied to a seller with no subscription history at all.
  /// Enforced to be unique-among-active by application code (like
  /// IntegrationSetting.isPrimary), not a DB constraint.
  isDefault            Boolean  @default(false) @map("is_default")
  isActive             Boolean  @default(true) @map("is_active")
  sortOrder            Int      @default(0) @map("sort_order")
  createdById          String?  @map("created_by_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  createdBy     User?                @relation(fields: [createdById], references: [id], onDelete: SetNull)
  subscriptions SellerSubscription[]
  features      PlanFeature[]

  @@index([isActive])
  @@map("subscription_plans")
}

/// Feature flags scoped to a specific plan, editable from the admin plans UI
/// with no code deploy — `featureKey` is a free string matching a
/// `FeatureKey` value in code (see services/monetization/entitlement.service.ts).
/// This is deliberately separate from the fixed boolean columns above
/// (maxProducts, hasAnalyticsAccess, etc.): those are the small, stable set
/// of "core" limits with dedicated enforcement already wired elsewhere;
/// this table is for anything added later (AI features first) without a
/// schema migration each time.
model PlanFeature {
  id           String   @id @default(cuid())
  planId       String   @map("plan_id")
  featureKey   String   @map("feature_key")
  enabled      Boolean  @default(false)
  /// Null = no cap (still gated by `enabled`, just unlimited uses per cycle).
  monthlyLimit Int?     @map("monthly_limit")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@map("plan_features")
}

/// Real per-seller, per-feature usage counting for anything with a
/// monthly cap (AI features today). Cycle = calendar month, not the
/// seller's individual subscription renewal date — simpler, and matches
/// "N actions/month" exactly. One row per (seller, feature, month);
/// `count` increments only on a successful use, never on a failed call.
model AiFeatureUsage {
  id         String   @id @default(cuid())
  sellerId   String   @map("seller_id")
  featureKey String   @map("feature_key")
  cycleStart DateTime @map("cycle_start")
  count      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  seller SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, featureKey, cycleStart])
  @@map("ai_feature_usages")
}

/// One row per subscription period a seller has ever had — history is kept
/// (never overwritten), so "current" means the single row with
/// status ACTIVE (enforced by application code, not a DB constraint, since
/// a seller legitimately accumulates many EXPIRED/CANCELLED rows over time).
model SellerSubscription {
  id                    String             @id @default(cuid())
  sellerId              String             @map("seller_id")
  planId                String             @map("plan_id")
  status                SubscriptionStatus @default(PENDING)
  startedAt             DateTime?          @map("started_at")
  expiresAt             DateTime?          @map("expires_at")
  boostCreditsRemaining Int                @default(0) @map("boost_credits_remaining")
  cancelledAt           DateTime?          @map("cancelled_at")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  seller   SellerProfile         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan      @relation(fields: [planId], references: [id])
  payments MonetizationPayment[]

  @@index([sellerId, status])
  @@index([status, expiresAt])
  @@map("seller_subscriptions")
}

/// A seller's paid visibility campaign for one product. Performance
/// (impressions/views/saves/orders) is deliberately NOT stored here — it's
/// derived on read from the existing ProductEvent stream and OrderItem
/// table, scoped to [startDate, endDate], so there's exactly one source of
/// truth for view/save counts instead of a second counter that could drift.
model BoostCampaign {
  id           String      @id @default(cuid())
  sellerId     String      @map("seller_id")
  productId    String      @map("product_id")
  goal         BoostGoal
  durationDays Int         @map("duration_days")
  creditsCost  Int         @map("credits_cost")
  status       BoostStatus @default(PENDING_PAYMENT)
  startDate    DateTime?   @map("start_date")
  endDate      DateTime?   @map("end_date")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  seller   SellerProfile         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  product  Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  payments MonetizationPayment[]

  @@index([sellerId])
  @@index([productId, status])
  @@index([status, endDate])
  @@map("boost_campaigns")
}

/// Payment record for subscription/boost charges — deliberately separate
/// from `Payment` (which is 1:1 with an Order and drives escrow/commission
/// splitting). A subscription or boost charge is 100% platform revenue with
/// no seller split, so it doesn't belong on that model. Reuses the same
/// provider integration layer and the same append-only ledger underneath.
model MonetizationPayment {
  id                String                    @id @default(cuid())
  sellerId          String                    @map("seller_id")
  purpose           MonetizationPurpose
  subscriptionId    String?                   @map("subscription_id")
  boostCampaignId   String?                   @map("boost_campaign_id")
  amount            Decimal                   @db.Decimal(10, 2)
  currency          String                    @default("NGN")
  provider          String
  providerReference String?                   @unique @map("provider_reference")
  status            MonetizationPaymentStatus @default(PENDING)
  createdAt         DateTime                  @default(now()) @map("created_at")
  updatedAt         DateTime                  @updatedAt @map("updated_at")

  seller        SellerProfile       @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  subscription  SellerSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  boostCampaign BoostCampaign?      @relation(fields: [boostCampaignId], references: [id], onDelete: SetNull)

  @@index([sellerId])
  @@index([status])
  @@map("monetization_payments")
}

/// Phase-10 placeholder for the future "Selecta Growth Partner" managed
/// service — intentionally minimal (application intake only, no delivery
/// workflow yet).
model GrowthPartnerApplication {
  id                String                  @id @default(cuid())
  sellerId          String                  @map("seller_id")
  status            GrowthApplicationStatus @default(PENDING)
  message           String?
  assignedManagerId String?                 @map("assigned_manager_id")
  notes             String?
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  seller          SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  assignedManager User?         @relation(fields: [assignedManagerId], references: [id], onDelete: SetNull)

  @@index([sellerId])
  @@index([status])
  @@map("growth_partner_applications")
}

// ---------------------------------------------------------------------------
// Security
// ---------------------------------------------------------------------------

/// Persisted fixed-window rate-limit counters (login attempts, messages
/// sent, checkout attempts, etc.) — replaces an in-process Map that gave no
/// real protection on serverless, where each invocation can land on a
/// different instance with its own empty memory. `key` is a caller-chosen
/// string like "login:user@example.com:203.0.113.1"; the row is reused
/// (not reset to a new row) once its window has passed, so this table
/// self-bounds in size rather than growing forever.
model RateLimitEntry {
  key     String   @id
  count   Int      @default(1)
  resetAt DateTime @map("reset_at")

  @@index([resetAt])
  @@map("rate_limit_entries")
}
