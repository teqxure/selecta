# Copy to .env and fill in real values. Never commit .env.

# --- Database (Neon Postgres) ------------------------------------------------
# Pooled connection string (PgBouncer) — used by the app at runtime.
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require"
# Direct (unpooled) connection string — used by Prisma Migrate.
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require"

# --- Auth ---------------------------------------------------------------------
# Random 64+ char secret used to sign session JWTs. Generate with:
#   openssl rand -base64 48
SESSION_SECRET=""

# --- Scaleway Object Storage ----------------------------------------------------
SCALEWAY_ACCESS_KEY_ID=""
SCALEWAY_SECRET_ACCESS_KEY=""
SCALEWAY_BUCKET_NAME=""
SCALEWAY_REGION="fr-par"
SCALEWAY_ENDPOINT="https://s3.fr-par.scw.cloud"

# --- App ------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
