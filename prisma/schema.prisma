// Selecta database schema.
// Foundational models only — kept intentionally minimal per phase-1 scope.
// Connection URLs live in `prisma.config.ts` / `.env` (Prisma 7 no longer
// reads `url`/`directUrl` from the datasource block).

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  BUYER
  SELLER
  AGENT
  ADMIN
  SUPER_ADMIN
}

enum SellerVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
}

enum SellerProductType {
  MALE_CLOTHES
  FEMALE_CLOTHES
  CHILDREN_CLOTHES
  SHOES
  BAGS
  ACCESSORIES
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  PAUSED
  SOLD
  REJECTED
  REMOVED
}

enum ConditionGrade {
  SELECTA_GOLD
  SELECTA_CLASSIC
  SELECTA_VALUE
}

enum ProductGender {
  MALE
  FEMALE
  UNISEX
  KIDS
}

enum ProductImageKind {
  FRONT
  BACK
  DETAIL
  DEFECT
  OTHER
}

enum ProductEventType {
  VIEW
  SAVE
  UNSAVE
  SHARE
  CONTACT_SELLER
}

enum OrderStatus {
  CREATED
  AWAITING_PAYMENT
  PAID
  PROCESSING
  READY_FOR_PICKUP
  IN_TRANSIT
  DELIVERED
  COMPLETED
  DISPUTED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  HELD_IN_ESCROW
  RELEASED
  REFUNDED
  FAILED
}

/// Per-seller payout ledger status — a superset of Payment's lifecycle
/// because escrow hold/release happens per seller, not per order (one
/// order can contain items from several sellers).
enum TransactionStatus {
  PENDING
  SUCCESSFUL
  FAILED
  HELD_IN_ESCROW
  RELEASED
  REFUNDED
}

enum DeliveryStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum DeliveryMethod {
  MANUAL
  PARTNER
}

enum WithdrawalStatus {
  REQUESTED
  PROCESSING
  PAID
  REJECTED
}

enum DisputeType {
  WRONG_ITEM
  DAMAGED_ITEM
  NOT_RECEIVED
  OTHER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_REFUND
  RESOLVED_RELEASE
  RESOLVED_PARTIAL
  CLOSED
}

enum IntegrationCategory {
  PAYMENT
  STORAGE
  EMAIL
  SMS
  AI
}

enum MarketplaceStatus {
  OPEN
  PAUSED
  CLOSED
}

enum NotificationType {
  ORDER
  PAYMENT
  DELIVERY
  SYSTEM
  PROMOTION
  MESSAGE
}

// ---------------------------------------------------------------------------
// Core identity
// ---------------------------------------------------------------------------

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  phone           String?    @unique
  passwordHash    String?    @map("password_hash")
  firstName       String     @map("first_name")
  lastName        String     @map("last_name")
  avatarUrl       String?    @map("avatar_url")
  role            Role       @default(BUYER)
  status          UserStatus @default(ACTIVE)
  /// Individually-granted permission strings — only meaningful when role
  /// is ADMIN. SUPER_ADMIN's authority is implicit (wildcard, never
  /// stored); SELLER/BUYER get a fixed role-wide set defined in code, not
  /// per-user grants. See lib/auth/permissions.ts.
  permissions     String[]   @default([])
  city            String?
  state           String?
  preferences     Json?
  emailVerifiedAt DateTime?  @map("email_verified_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  sellerProfile   SellerProfile?
  wallet          Wallet?
  orders          Order[]
  reviews         Review[]
  notifications   Notification[]
  deliveries      Delivery[]      @relation("AgentDeliveries")
  auditLogs       AuditLog[]
  addresses       Address[]
  activities      UserActivity[]
  loginHistory    LoginHistory[]
  assignedSellers SellerProfile[] @relation("SellerAgent")
  savedProducts   SavedProduct[]
  productEvents   ProductEvent[]
  cartItems       CartItem[]
  storeFollows    StoreFollow[]
  conversations   Conversation[]  @relation("BuyerConversations")
  messages        Message[]

  transactionsAsBuyer    Transaction[]        @relation("BuyerTransactions")
  orderStatusChanges     OrderStatusHistory[]
  withdrawalReviews      Withdrawal[]         @relation("WithdrawalReviewer")
  disputesAsBuyer        Dispute[]            @relation("BuyerDisputes")
  disputesResolved       Dispute[]            @relation("ResolvedDisputes")
  systemSettingsUpdated  SystemSettings[]
  integrationSettingsSet IntegrationSetting[]
  commissionRulesCreated CommissionRule[]
  featureFlagsUpdated    FeatureFlag[]

  @@index([role])
  @@index([status])
  @@map("users")
}

model SellerProfile {
  id                    String                   @id @default(cuid())
  userId                String                   @unique @map("user_id")
  businessName          String                   @map("business_name")
  storeName             String?                  @map("store_name")
  storeSlug             String?                  @unique @map("store_slug")
  bannerUrl             String?                  @map("banner_url")
  bio                   String?
  marketLocation        String?                  @map("market_location")
  city                  String?
  state                 String?
  country               String                   @default("Nigeria")
  categoryTags          SellerProductType[]      @map("category_tags")
  verificationStatus    SellerVerificationStatus @default(PENDING) @map("verification_status")
  ratingAverage         Float                    @default(0) @map("rating_average")
  ratingCount           Int                      @default(0) @map("rating_count")
  totalSales            Int                      @default(0) @map("total_sales")
  followerCount         Int                      @default(0) @map("follower_count")
  profileViewCount      Int                      @default(0) @map("profile_view_count")
  onboardingStep        Int                      @default(1) @map("onboarding_step")
  onboardingCompletedAt DateTime?                @map("onboarding_completed_at")
  agentId               String?                  @map("agent_id")
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent         User?               @relation("SellerAgent", fields: [agentId], references: [id], onDelete: SetNull)
  products      Product[]
  verification  SellerVerification?
  followers     StoreFollow[]
  conversations Conversation[]
  transactions  Transaction[]
  withdrawals   Withdrawal[]
  disputes      Dispute[]

  @@index([verificationStatus])
  @@index([agentId])
  @@map("seller_profiles")
}

/// A buyer following a store — also doubles as "save store" (section 4),
/// same one-tap-interaction pattern as SavedProduct in the catalog phase.
model StoreFollow {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  sellerProfileId String   @map("seller_profile_id")
  createdAt       DateTime @default(now()) @map("created_at")

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@unique([userId, sellerProfileId])
  @@index([sellerProfileId])
  @@map("store_follows")
}

/// Seller onboarding step 3 submission: documents + admin review trail.
/// `SellerProfile.verificationStatus` is a denormalized copy of `status`
/// here, kept in sync by the seller-verification service, so RBAC/UI checks
/// never need to join into this table.
model SellerVerification {
  id                  String                   @id @default(cuid())
  sellerProfileId     String                   @unique @map("seller_profile_id")
  businessPhotoUrl    String?                  @map("business_photo_url")
  shopPhotoUrl        String?                  @map("shop_photo_url")
  identityDocumentUrl String?                  @map("identity_document_url")
  status              SellerVerificationStatus @default(PENDING)
  reviewedById        String?                  @map("reviewed_by_id")
  reviewNotes         String?                  @map("review_notes")
  submittedAt         DateTime                 @default(now()) @map("submitted_at")
  reviewedAt          DateTime?                @map("reviewed_at")

  sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("seller_verifications")
}

model Address {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  label     String?
  line1     String
  line2     String?
  city      String
  state     String
  country   String   @default("Nigeria")
  phone     String?
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

/// Lightweight behavioral event stream (logins, views, profile edits).
/// Distinct from `AuditLog`, which is the admin-facing security/audit trail
/// keyed by entity rather than by user.
model UserActivity {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("user_activities")
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  success   Boolean
  reason    String?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("login_history")
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  imageUrl  String?  @map("image_url")
  parentId  String?  @map("parent_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent          Category?        @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children        Category[]       @relation("CategoryHierarchy")
  products        Product[]        @relation("ProductCategory")
  subcategoryOf   Product[]        @relation("ProductSubcategory")
  commissionRules CommissionRule[]

  @@index([parentId])
  @@map("categories")
}

model Product {
  id              String         @id @default(cuid())
  sellerId        String         @map("seller_id")
  categoryId      String         @map("category_id")
  subcategoryId   String?        @map("subcategory_id")
  title           String
  description     String?
  brand           String?
  color           String?
  gender          ProductGender?
  size            String?
  price           Decimal        @db.Decimal(10, 2)
  discountPrice   Decimal?       @map("discount_price") @db.Decimal(10, 2)
  estimatedValue  Decimal?       @map("estimated_value") @db.Decimal(10, 2)
  currency        String         @default("NGN")
  quantity        Int            @default(1)
  conditionGrade  ConditionGrade @default(SELECTA_CLASSIC) @map("condition_grade")
  status          ProductStatus  @default(DRAFT)
  material        String?
  city            String?
  state           String?
  market          String?
  pickupLocation  String?        @map("pickup_location")
  viewCount       Int            @default(0) @map("view_count")
  likeCount       Int            @default(0) @map("like_count")
  shareCount      Int            @default(0) @map("share_count")
  isFeatured      Boolean        @default(false) @map("is_featured")
  rejectionReason String?        @map("rejection_reason")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  seller      SellerProfile  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category    Category       @relation("ProductCategory", fields: [categoryId], references: [id])
  subcategory Category?      @relation("ProductSubcategory", fields: [subcategoryId], references: [id], onDelete: SetNull)
  images      ProductImage[]
  orderItems  OrderItem[]
  reviews     Review[]
  savedBy     SavedProduct[]
  events      ProductEvent[]
  cartItems   CartItem[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([status])
  @@index([city, state])
  @@index([isFeatured])
  @@map("products")
}

model ProductImage {
  id            String           @id @default(cuid())
  productId     String           @map("product_id")
  url           String
  kind          ProductImageKind @default(OTHER)
  position      Int              @default(0)
  // Hooks for a future AI pipeline (background removal / enhancement /
  // auto quality scoring) — left null until that service exists.
  processedUrl  String?          @map("processed_url")
  qualityScore  Float?           @map("quality_score")
  aiProcessedAt DateTime?        @map("ai_processed_at")
  createdAt     DateTime         @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
  @@map("product_images")
}

/// Doubles as "like" (section 6/1) and "save" (section 9) — a single tap
/// interaction in the UI, so one model rather than two near-duplicates.
model SavedProduct {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@map("saved_products")
}

/// Raw event stream backing the denormalized Product counters and future
/// recommendation/analytics work — counters stay fast to read, this stays
/// the source of truth for aggregation.
model ProductEvent {
  id        String           @id @default(cuid())
  productId String           @map("product_id")
  userId    String?          @map("user_id")
  type      ProductEventType
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId, type, createdAt])
  @@index([userId])
  @@map("product_events")
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("cart_items")
}

// ---------------------------------------------------------------------------
// Commerce
// ---------------------------------------------------------------------------

model Order {
  id              String      @id @default(cuid())
  buyerId         String      @map("buyer_id")
  status          OrderStatus @default(CREATED)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(10, 2)
  currency        String      @default("NGN")
  shippingAddress Json        @map("shipping_address")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  buyer         User                 @relation(fields: [buyerId], references: [id])
  items         OrderItem[]
  payment       Payment?
  delivery      Delivery?
  transactions  Transaction[]
  statusHistory OrderStatusHistory[]
  disputes      Dispute[]

  @@index([buyerId])
  @@index([status])
  @@map("orders")
}

/// Every order status change is recorded here — the timeline shown to
/// buyer/seller/admin, and the audit trail for "who moved this order and
/// when." `actorId` is null for system/webhook-driven transitions.
model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String      @map("order_id")
  status    OrderStatus
  note      String?
  actorId   String?     @map("actor_id")
  createdAt DateTime    @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@map("order_status_history")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  unitPrice Decimal  @map("unit_price") @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

/// The buyer-facing capture: one Payment per Order, matching the single
/// charge the provider actually processes. Escrow hold/release happens
/// per seller below in `Transaction`, not here.
model Payment {
  id                String        @id @default(cuid())
  orderId           String        @unique @map("order_id")
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @default("NGN")
  provider          String
  providerReference String?       @unique @map("provider_reference")
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([status])
  @@map("payments")
}

/// The seller-facing payout ledger: one row per (order, seller) pair,
/// created once payment succeeds, carrying the commission split so a
/// seller's payout is never recomputed from scratch — it's the number
/// that was actually charged and committed at the time.
model Transaction {
  id               String            @id @default(cuid())
  orderId          String            @map("order_id")
  paymentId        String?           @map("payment_id")
  buyerId          String            @map("buyer_id")
  sellerId         String            @map("seller_id")
  amount           Decimal           @db.Decimal(10, 2)
  commissionRate   Float             @map("commission_rate")
  commissionAmount Decimal           @map("commission_amount") @db.Decimal(10, 2)
  sellerAmount     Decimal           @map("seller_amount") @db.Decimal(10, 2)
  currency         String            @default("NGN")
  provider         String
  reference        String?           @unique
  status           TransactionStatus @default(PENDING)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  order   Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  buyer   User          @relation("BuyerTransactions", fields: [buyerId], references: [id])
  seller  SellerProfile @relation(fields: [sellerId], references: [id])

  @@index([sellerId, status])
  @@index([orderId])
  @@index([status])
  @@map("transactions")
}

model Wallet {
  id               String   @id @default(cuid())
  userId           String   @unique @map("user_id")
  balance          Decimal  @default(0) @db.Decimal(10, 2)
  /// Lifetime earnings — never decreases, even once a future withdrawal
  /// phase starts deducting from `balance`. Distinct source of truth from
  /// `balance` on purpose.
  totalEarned      Decimal  @default(0) @map("total_earned") @db.Decimal(10, 2)
  /// Cumulative amount paid out via approved withdrawals.
  withdrawnBalance Decimal  @default(0) @map("withdrawn_balance") @db.Decimal(10, 2)
  currency         String   @default("NGN")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model Withdrawal {
  id            String           @id @default(cuid())
  sellerId      String           @map("seller_id")
  amount        Decimal          @db.Decimal(10, 2)
  bankName      String           @map("bank_name")
  accountNumber String           @map("account_number")
  accountName   String           @map("account_name")
  status        WithdrawalStatus @default(REQUESTED)
  reviewedById  String?          @map("reviewed_by_id")
  reviewNotes   String?          @map("review_notes")
  requestedAt   DateTime         @default(now()) @map("requested_at")
  processedAt   DateTime?        @map("processed_at")

  seller     SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  reviewedBy User?         @relation("WithdrawalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([sellerId, status])
  @@map("withdrawals")
}

model Review {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  authorId  String   @map("author_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@index([productId])
  @@map("reviews")
}

// ---------------------------------------------------------------------------
// Logistics
// ---------------------------------------------------------------------------

model Delivery {
  id             String         @id @default(cuid())
  orderId        String         @unique @map("order_id")
  agentId        String?        @map("agent_id")
  status         DeliveryStatus @default(PENDING)
  method         DeliveryMethod @default(MANUAL)
  address        Json
  pickupLocation String?        @map("pickup_location")
  deliveryFee    Decimal?       @map("delivery_fee") @db.Decimal(10, 2)
  trackingCode   String?        @unique @map("tracking_code")
  estimatedAt    DateTime?      @map("estimated_at")
  deliveredAt    DateTime?      @map("delivered_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  order  Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  agent  User?           @relation("AgentDeliveries", fields: [agentId], references: [id])
  events DeliveryEvent[]

  @@index([agentId])
  @@index([status])
  @@map("deliveries")
}

model DeliveryEvent {
  id         String         @id @default(cuid())
  deliveryId String         @map("delivery_id")
  status     DeliveryStatus
  note       String?
  createdAt  DateTime       @default(now()) @map("created_at")

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId, createdAt])
  @@map("delivery_events")
}

// ---------------------------------------------------------------------------
// Messaging (foundation — buyer/seller only, no groups, no attachments yet)
// ---------------------------------------------------------------------------

model Conversation {
  id              String   @id @default(cuid())
  buyerId         String   @map("buyer_id")
  sellerProfileId String   @map("seller_profile_id")
  lastMessageAt   DateTime @default(now()) @map("last_message_at")
  createdAt       DateTime @default(now()) @map("created_at")

  buyer         User          @relation("BuyerConversations", fields: [buyerId], references: [id], onDelete: Cascade)
  sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@unique([buyerId, sellerProfileId])
  @@index([sellerProfileId, lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  senderId       String    @map("sender_id")
  body           String
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ---------------------------------------------------------------------------
// Platform
// ---------------------------------------------------------------------------

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Disputes
// ---------------------------------------------------------------------------

model Dispute {
  id           String        @id @default(cuid())
  orderId      String        @map("order_id")
  buyerId      String        @map("buyer_id")
  sellerId     String        @map("seller_id")
  type         DisputeType
  description  String
  evidenceUrls String[]      @map("evidence_urls")
  status       DisputeStatus @default(OPEN)
  resolution   String?
  resolvedById String?       @map("resolved_by_id")
  resolvedAt   DateTime?     @map("resolved_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  order      Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyer      User          @relation("BuyerDisputes", fields: [buyerId], references: [id])
  seller     SellerProfile @relation(fields: [sellerId], references: [id])
  resolvedBy User?         @relation("ResolvedDisputes", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([sellerId])
  @@index([orderId])
  @@map("disputes")
}

// ---------------------------------------------------------------------------
// Super Admin platform controls
// ---------------------------------------------------------------------------

/// Singleton row (fixed id "singleton") — global marketplace switches.
model SystemSettings {
  id                        String            @id @default("singleton")
  platformName              String            @default("Selecta") @map("platform_name")
  maintenanceMode           Boolean           @default(false) @map("maintenance_mode")
  maintenanceMessage        String?           @map("maintenance_message")
  allowNewSellers           Boolean           @default(true) @map("allow_new_sellers")
  allowNewBuyers            Boolean           @default(true) @map("allow_new_buyers")
  requireProductApproval    Boolean           @default(true) @map("require_product_approval")
  requireSellerVerification Boolean           @default(true) @map("require_seller_verification")
  marketplaceStatus         MarketplaceStatus @default(OPEN) @map("marketplace_status")
  updatedById               String?           @map("updated_by_id")
  updatedAt                 DateTime          @updatedAt @map("updated_at")

  updatedBy User? @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("system_settings")
}

/// One row per (category, provider) — e.g. (PAYMENT, "paystack"),
/// (STORAGE, "cloudflare-r2"). Actual credentials live in `IntegrationSecret`,
/// never here — this row only holds non-secret config + enable state.
model IntegrationSetting {
  id          String              @id @default(cuid())
  category    IntegrationCategory
  provider    String
  isEnabled   Boolean             @default(false) @map("is_enabled")
  isPrimary   Boolean             @default(false) @map("is_primary")
  config      Json?
  updatedById String?             @map("updated_by_id")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  updatedBy User?               @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  secrets   IntegrationSecret[]

  @@unique([category, provider])
  @@map("integration_settings")
}

/// Encrypted-at-rest credential values. `encryptedValue` is AES-256-GCM
/// ciphertext (iv+authTag+ciphertext packed, base64) — see
/// lib/security/encryption.ts. Only `lastFourDisplay` (plaintext) is ever
/// shown in the UI, masked like `********************x7d9`.
model IntegrationSecret {
  id                   String   @id @default(cuid())
  integrationSettingId String   @map("integration_setting_id")
  key                  String
  encryptedValue       String   @map("encrypted_value")
  lastFourDisplay      String   @map("last_four_display")
  rotatedAt            DateTime @default(now()) @map("rotated_at")
  createdAt            DateTime @default(now()) @map("created_at")

  integrationSetting IntegrationSetting @relation(fields: [integrationSettingId], references: [id], onDelete: Cascade)

  @@unique([integrationSettingId, key])
  @@map("integration_secrets")
}

/// `categoryId = null` is the platform default rate. A category-specific
/// row overrides the default for that category. No commission is ever
/// hardcoded in application code — see services/platform/commission.service.ts.
model CommissionRule {
  id            String    @id @default(cuid())
  categoryId    String?   @map("category_id")
  label         String
  percentage    Float
  isPromotional Boolean   @default(false) @map("is_promotional")
  startsAt      DateTime? @map("starts_at")
  endsAt        DateTime? @map("ends_at")
  isActive      Boolean   @default(true) @map("is_active")
  createdById   String?   @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  category  Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([isActive])
  @@map("commission_rules")
}

model FeatureFlag {
  key         String   @id
  label       String
  description String?
  isEnabled   Boolean  @default(false) @map("is_enabled")
  updatedById String?  @map("updated_by_id")
  updatedAt   DateTime @updatedAt @map("updated_at")

  updatedBy User? @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("feature_flags")
}
